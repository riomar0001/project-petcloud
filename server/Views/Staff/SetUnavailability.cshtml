@{
    Layout = "~/Views/Shared/_DashboardLayoutModern.cshtml";
    ViewBag.Title = "Set Unavailability";
}

<div class="p-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb breadcrumb-modern">
            <li class="breadcrumb-item"><a href="/Staff/Appointments">Appointments</a></li>
            <li class="breadcrumb-item active">Set Unavailability</li>
        </ol>
    </nav>

    <h5 class="fw-bold mb-4">Appointments / Set Unavailability</h5>

    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1055">
        <div id="messageToast" class="toast align-items-center text-white border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <div class="card-accent p-4" style="max-width: 680px;">
        <h6 class="card-header-modern mb-4"><i class="bi bi-calendar-x me-2"></i>Block Schedule</h6>

        <div class="form-group-modern mb-3">
            <label class="form-label fw-semibold">Staff Member</label>
            <input type="text" class="form-control form-control-modern" value="@ViewBag.CurrentStaffName" readonly />
        </div>

        <form id="unavailabilityForm" method="post" action="/Staff/SetUnavailability">
            @Html.AntiForgeryToken()

            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label fw-semibold">Start Date</label>
                        <input type="date" name="startDate" id="startDate" class="form-control form-control-modern" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label fw-semibold">End Date</label>
                        <input type="date" name="endDate" id="endDate" class="form-control form-control-modern" required />
                    </div>
                </div>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" name="wholeDay" id="wholeDayToggle" value="true" checked />
                <label class="form-check-label fw-semibold" for="wholeDayToggle">Whole Day</label>
            </div>

            <div id="timeRangeSection" class="row mb-3" style="display:none;">
                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label fw-semibold">Start Time</label>
                        <input type="time" name="startTime" id="startTime" class="form-control form-control-modern" min="09:00" max="18:00" step="300" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label fw-semibold">End Time</label>
                        <input type="time" name="endTime" id="endTime" class="form-control form-control-modern" min="09:00" max="18:00" step="300" />
                    </div>
                </div>
            </div>

            <div class="form-group-modern mb-4">
                <label class="form-label fw-semibold">Reason / Note <span class="text-muted fw-normal">(optional)</span></label>
                <textarea name="reason" class="form-control form-control-modern" rows="2" placeholder="e.g. Vacation, Lunch, Doctor's Appointment"></textarea>
            </div>

            <button type="submit" class="btn-modern-primary w-100">
                <i class="bi bi-lock-fill me-2"></i>Block Schedule
            </button>
        </form>

        <div id="resultAlert" class="mt-3" style="display:none;"></div>
    </div>

    <div class="card-accent p-4 mt-4" style="max-width: 680px;">
        <h6 class="card-header-modern mb-3"><i class="bi bi-list-ul me-2"></i>Upcoming Blocked Slots</h6>
        <div id="blocksTableWrapper">
            <div class="text-muted small">Loading...</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toggle time range visibility
        const wholeDayToggle = document.getElementById('wholeDayToggle');
        const timeRangeSection = document.getElementById('timeRangeSection');

        wholeDayToggle.addEventListener('change', function () {
            timeRangeSection.style.display = this.checked ? 'none' : 'flex';
        });

        const antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

        function loadBlocks() {
            $.get('/Staff/GetUnavailabilityBlocks', function (data) {
                const wrapper = document.getElementById('blocksTableWrapper');
                if (!data.length) {
                    wrapper.innerHTML = '<div class="text-muted small">No upcoming blocked slots.</div>';
                    return;
                }
                let rows = data.map(b => `
                    <tr>
                        <td>${b.dateLabel}</td>
                        <td>${b.count} slot(s)</td>
                        <td>${b.reason || '—'}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger cancel-btn" data-date="${b.date}">
                                <i class="bi bi-x-circle me-1"></i>Cancel
                            </button>
                        </td>
                    </tr>`).join('');
                wrapper.innerHTML = `
                    <table class="table table-modern-list table-sm">
                        <thead><tr>
                            <th>Date</th><th>Slots</th><th>Reason</th><th></th>
                        </tr></thead>
                        <tbody>${rows}</tbody>
                    </table>`;

                wrapper.querySelectorAll('.cancel-btn').forEach(btn => {
                    btn.addEventListener('click', function () {
                        const date = this.dataset.date;
                        if (!confirm(`Cancel all your blocks on ${date}?`)) return;
                        $.ajax({
                            url: '/Staff/CancelUnavailabilityByDate',
                            type: 'POST',
                            data: { date, __RequestVerificationToken: antiForgeryToken },
                            success: function (res) {
                                const toast = document.getElementById('messageToast');
                                toast.classList.toggle('bg-success', res.success);
                                toast.classList.toggle('bg-danger', !res.success);
                                toast.querySelector('.toast-body').textContent = res.message;
                                new bootstrap.Toast(toast).show();
                                if (res.success) loadBlocks();
                            }
                        });
                    });
                });
            });
        }

        loadBlocks();

        // AJAX form submit
        document.getElementById('unavailabilityForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const form = this;
            const btn = form.querySelector('button[type=submit]');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Blocking...';

            $.ajax({
                url: form.action,
                type: 'POST',
                data: $(form).serialize(),
                success: function (res) {
                    const alert = document.getElementById('resultAlert');
                    alert.style.display = 'block';
                    alert.className = res.success ? 'alert alert-success' : 'alert alert-danger';
                    alert.textContent = res.message;

                    const toast = document.getElementById('messageToast');
                    toast.classList.toggle('bg-success', res.success);
                    toast.classList.toggle('bg-danger', !res.success);
                    toast.querySelector('.toast-body').textContent = res.message;
                    new bootstrap.Toast(toast).show();

                    if (res.success) { form.reset(); loadBlocks(); }
                },
                error: function () {
                    const alert = document.getElementById('resultAlert');
                    alert.style.display = 'block';
                    alert.className = 'alert alert-danger';
                    alert.textContent = 'An unexpected error occurred.';
                },
                complete: function () {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-lock-fill me-2"></i>Block Schedule';
                }
            });
        });
    </script>
}
